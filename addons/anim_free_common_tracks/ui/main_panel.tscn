[node name="Label4" type="Label" parent="HBoxContainer/PluginIntroductionPanel/ScrollContainer/VBoxContainer"]
custom_minimum_size = Vector2(180, 0)
layout_mode = 2
text = "插件简介：
1、对godot动画资源文件更新，检测每个动画资源中值不变的轨道，若所有动画文件中不变轨道值相同，删除所有动画文件中的该轨道。同时删除动画文件中visible为空的节点的其余轨道（跳过含_ground字符串的节点）
2、可以选择目录（非递归），对选择目录下的所有动画文件处理。也可以选择场景，对场景中的所有animationplay节点（递归查找所有节点）的动画处理
3、在“输出”面板会输出详细信息
4、在使用场景文件时，要输入场景文件中的AnimationPlayer节点名字,否则会选择所有的AnimationPlayer节点(多动画节点时，尤其注意僵尸灰烬动画)
5、豌豆射手这种头和身体分开的，可以将头的动画和身体的动画分到两个文件夹下，选择动画文件目录处理。
6、实现了动画文件夹路径的选择和自动保存"
vertical_alignment = 1
autowrap_mode = 3
